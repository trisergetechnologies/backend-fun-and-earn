# Dream Mart (backend-fun-and-earn) — copy to .env and fill in values

NODE_ENV=development
PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/fun_n_earn_db

JWT_SECRET=your-jwt-secret

# razorpay | ccavenue | orange_pg
# Payment gateway: client sends paymentGateway on createorderintent (razorpay default if omitted).
# Configure both Razorpay and CCAvenue credentials; routing is per app build.
PAYMENT_GATEWAY=razorpay

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

CCAVENUE_MERCHANT_ID=
CCAVENUE_ACCESS_CODE=
CCAVENUE_WORKING_KEY=
# live = secure.ccavenue.com | test = test.ccavenue.com
CCAVENUE_ENV=live

# Production: https://amp-api.mpdreams.in/api/v1
# Local/ngrok: https://your-subdomain.ngrok-free.app/api/v1
BACKEND_URL=https://amp-api.mpdreams.in/api/v1
# CCAvenue whitelist (public routes, no auth):
#   {BACKEND_URL}/public/ccavenue/callback
#   {BACKEND_URL}/public/ccavenue/cancel
FRONTEND_URL=dreammart://

ORANGE_MERCHANT_ID=
ORANGE_MERCHANT_SECRET=
ORANGE_BASE_URL=https://qa.phicommerce.com

ORDER_HOLD_WINDOW_MINUTES=30

EMAIL_USER=
EMAIL_PASS=
EMAIL_USER_TO_SHOW=no-reply@mpdreams.in

ADMIN_EMAIL=

BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=

REWARD_PAYOUT_SKIP_ELIGIBILITY_CHECK=false
MAX_PLATFORM_VIDEOS=200
VIDEO_RETENTION_BATCH_SIZE=20
TEAM_TREE_MODE=legacy
