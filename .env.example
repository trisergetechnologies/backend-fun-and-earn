# Weekly/monthly payout eligibility for achievement levels 1–3 (see docs/REWARD_PAYOUT.md)
# false (default) = enforce new-downline-buyer thresholds; share = perLevel / eligible users only
# true = skip eligibility; all achievers at each level split that level's bucket
REWARD_PAYOUT_SKIP_ELIGIBILITY_CHECK=false

# Short video platform retention (global cap; daily cron evicts oldest beyond cap)
MAX_PLATFORM_VIDEOS=200
VIDEO_RETENTION_BATCH_SIZE=20
